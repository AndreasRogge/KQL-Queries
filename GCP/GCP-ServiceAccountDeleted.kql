GCPAuditLogs
| where MethodName =~ 'google.iam.admin.v1.DeleteServiceAccount'
| extend SrcIpAddr = parse_json(todynamic(RequestMetadata))['callerIp']
| where SrcIpAddr != "gce-internal-ip"
| extend SrcUserAgent = parse_json(todynamic(RequestMetadata))['callerSuppliedUserAgent']
//| where SrcUserAgent notcontains "google-api"
| extend Username = PrincipalEmail